# ─── APP ───────────────────────────────────────────
APP_NAME=Aquerii
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ─── DATABASE ──────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=aquerii
DB_USERNAME=aquerii_app
DB_PASSWORD=secret_app_password
DB_SUPERADMIN_USERNAME=aquerii_superadmin
DB_SUPERADMIN_PASSWORD=secret_superadmin_password

# ─── REDIS ─────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secret_redis_password

# ─── MEILISEARCH ───────────────────────────────────
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=secret_meilisearch_master_key

# ─── MINIO ─────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_KEY=minioadmin
MINIO_SECRET=minioadmin
MINIO_BUCKET=aquerii
MINIO_REGION=us-east-1

# ─── AI ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── STRIPE ────────────────────────────────────────
STRIPE_KEY=sk_test_your_stripe_key
STRIPE_SECRET=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── PAYFAST ───────────────────────────────────────
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase
PAYFAST_SANDBOX=true

# ─── MAIL ──────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=noreply@aquerii.app
MAIL_FROM_NAME="${APP_NAME}"

# ─── REALTIME SERVICE ──────────────────────────────
REALTIME_URL=http://realtime:3001
REALTIME_SECRET=secret_realtime_internal_key

# ─── AI SERVICE ────────────────────────────────────
AI_SERVICE_URL=http://ai:8002
AI_SERVICE_SECRET=secret_ai_internal_key

# ─── OAUTH ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost/auth/google/callback

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost/auth/github/callback

# ─── VAULT (production only) ───────────────────────
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-root-token

# ─── CLICKHOUSE ────────────────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=aquerii_analytics
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# ─── OTEL ──────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ─── SUPER ADMIN ───────────────────────────────────
SUPER_ADMIN_EMAIL=admin@aquerii.internal
SUPER_ADMIN_PASSWORD=ChangeMe_SuperAdmin_2026!
