{
    "name": "aquerii/super-admin",
    "description": "Aquerii Super Admin Panel",
    "require": {
        "php": "^8.3",
        "filament/filament": "^3.2",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.9",
        "pragmarx/google2fa-laravel": "^2.2",
        "bacon/bacon-qr-code": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-laravel": "^2.3"
    },
    "autoload": {
        "psr-4": { "App\\": "app/", "Database\\Factories\\": "database/factories/", "Database\\Seeders\\": "database/seeders/" }
    },
    "autoload-dev": {
        "psr-4": { "Tests\\": "tests/" }
    },
    "scripts": {
        "post-autoload-dump": ["Illuminate\\Foundation\\ComposerScripts::postAutoloadDump", "@php artisan package:discover --ansi"],
        "post-install-cmd": ["@php artisan key:generate --ansi"],
        "post-update-cmd": ["@php artisan vendor:publish --tag=laravel-assets --ansi --force"]
    },
    "config": { "optimize-autoloader": true, "preferred-install": "dist", "sort-packages": true },
    "minimum-stability": "stable",
    "prefer-stable": true
}
