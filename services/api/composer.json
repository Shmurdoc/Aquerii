{
    "name": "aquerii/api",
    "description": "Aquerii FlowOS — Laravel 11 API",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "laravel/horizon": "^5.24",
        "laravel/telescope": "^5.0",
        "filament/filament": "^3.2",
        "spatie/laravel-permission": "^6.7",
        "spatie/laravel-activitylog": "^4.8",
        "spatie/laravel-query-builder": "^5.8",
        "spatie/laravel-data": "^4.8",
        "spatie/laravel-media-library": "^11.7",
        "stripe/stripe-php": "^15.0",
        "google/cloud-aiplatform": "^0.21",
        "anthropic-sdk/anthropic-sdk": "^0.2",
        "league/flysystem-aws-s3-v3": "^3.28",
        "predis/predis": "^2.2",
        "open-telemetry/sdk": "^1.0",
        "open-telemetry/exporter-otlp": "^1.0",
        "open-telemetry/opentelemetry-auto-laravel": "^0.0.5",
        "tymon/jwt-auth": "^2.1",
        "league/oauth2-server": "^8.5",
        "socialiteproviders/google": "^4.8",
        "socialiteproviders/github": "^4.6",
        "laravel/socialite": "^5.14",
        "pragmarx/google2fa-laravel": "^2.2",
        "brick/math": "^0.12",
        "meilisearch/meilisearch-php": "^1.8",
        "laravel/scout": "^10.10",
        "lorisleiva/laravel-actions": "^2.8"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "laravel/pint": "^1.16",
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpstan/phpstan": "^1.11",
        "larastan/larastan": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "test": "pest --parallel",
        "lint": "pint --test",
        "analyse": "phpstan analyse --memory-limit=512M"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    }
}
